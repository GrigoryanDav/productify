{
    "compilerOptions": {
        "rootDir": "./src", // Where your source files are
        "outDir": "./dist", // Where compiled JS goes
        "module": "commonjs", // Output format (require/module.exports)
        "target": "es2022", // JS version to compile to (modern)
        "esModuleInterop": true, // Allows `import x from 'y'` syntax with CommonJS modules
        "strict": true, // Enables all strict type-checking
        "skipLibCheck": true, // Skips type-checking .d.ts files (faster builds)
        "moduleResolution": "node", // How TS finds modules (node_modules lookup)
        "ignoreDeprecations": "6.0", // Suppresses deprecation warnings for TS 6.0 features
        "resolveJsonModule": true, // Allows importing .json files
        "forceConsistentCasingInFileNames": true // Prevents case-sensitivity bugs        
    },
    "include": ["src/**/*.ts"], // Include all TS files in src
    "exclude": ["node_modules"] // Exclude dependencies
}